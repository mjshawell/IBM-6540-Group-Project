## From Records to Data

```{r}
#| label: import-data-template
#| eval: false

retail_raw <- read_csv("data/retail_sales_data.csv")

retail <- retail_raw |> 
  clean_names()

glimpse(retail)
```

---

## Tidying the Data

```{r}
#| label: tidy-data-template
#| eval: false

retail_tidy <- retail |> 
  mutate(
    date = mdy(date),
    month = month(date, label = TRUE),
    quarter = quarter(date),
    discount_group = case_when(
      discount_percentage <= 10 ~ "Low discount: 0-10%",
      discount_percentage <= 25 ~ "Moderate discount: 11-25%",
      discount_percentage > 25 ~ "High discount: 26%+",
      TRUE ~ "Missing"
    )
  )
```

---

## Transforming the Data

```{r}
#| label: transform-data-template
#| eval: false

sales_summary <- retail_tidy |> 
  group_by(product_category, discount_group) |> 
  summarise(
    avg_units_sold = mean(units_sold, na.rm = TRUE),
    avg_sales_revenue = mean(sales_revenue_usd, na.rm = TRUE),
    avg_marketing_spend = mean(marketing_spend_usd, na.rm = TRUE),
    records = n(),
    .groups = "drop"
  )

sales_summary
```

